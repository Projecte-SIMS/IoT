{
  "info": {
    "name": "FastAPI Agent Server",
    "_postman_id": "b7f9a2d4-6b1f-4c5a-9d3f-0a6b2e3c7f9a",
    "description": "Colección para verificar endpoints del servidor FastAPI y el agente, con controles de relé ON/OFF.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "agentId", "value": "pi-01", "type": "string" },
    { "key": "agentBaseUrl", "value": "http://1.2.3.4:8001", "type": "string" },
    { "key": "relay", "value": "1", "type": "string" },
    { "key": "action", "value": "on", "type": "string" }
  ],
  "item": [
    {
      "name": "Register Agent",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"agent_id\": \"{{agentId}}\",\n  \"callback_url\": \"{{agentBaseUrl}}\"\n}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/register", "host": ["{{baseUrl}}"], "path": ["register"] }
      }
    },
    {
      "name": "Get Agent Status",
      "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/agents/{{agentId}}/status", "host": ["{{baseUrl}}"], "path": ["agents", "{{agentId}}", "status"] } }
    },
    {
      "name": "Send Command to Agent (generic)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cmd\": \"relay\",\n  \"params\": { \"relay\": {{relay}}, \"action\": \"{{action}}\" }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "{{baseUrl}}/agents/{{agentId}}/command", "host": ["{{baseUrl}}"], "path": ["agents", "{{agentId}}", "command"] }
      }
    },
    {
      "name": "Relay ON",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"cmd\": \"relay\",\n  \"params\": { \"relay\": {{relay}}, \"action\": \"on\" }\n}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/agents/{{agentId}}/command", "host": ["{{baseUrl}}"], "path": ["agents", "{{agentId}}", "command"] }
      }
    },
    {
      "name": "Relay OFF",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"cmd\": \"relay\",\n  \"params\": { \"relay\": {{relay}}, \"action\": \"off\" }\n}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{baseUrl}}/agents/{{agentId}}/command", "host": ["{{baseUrl}}"], "path": ["agents", "{{agentId}}", "command"] }
      }
    },
    {
      "name": "Agent Direct /execute (optional)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"type\": \"command\",\n  \"cmd\": \"relay\",\n  \"cmd_id\": \"test-1\",\n  \"params\": { \"relay\": {{relay}}, \"action\": \"{{action}}\" }\n}", "options": { "raw": { "language": "json" } } },
        "url": { "raw": "{{agentBaseUrl}}/execute", "host": ["{{agentBaseUrl}}"], "path": ["execute"] }
      }
    }
  ]
}
