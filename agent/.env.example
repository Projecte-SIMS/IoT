# Configuración de Hardware (Opcional)
RELAY0_PIN=17

# ID del inquilino (TENANT)
# Ejemplo: feetly, sims, empresa_a
TENANT_ID=default

# ID del dispositivo (Cópialo de la interfaz web si quieres uno específico)
# Si está vacío, se genera automáticamente basado en el hardware
DEVICE_ID=

# Dirección del servidor WebSocket
# Para PRODUCCIÓN (Render): usar wss:// (WebSocket Secure)
# Para LOCAL: usar ws://
SERVER_WS=wss://sims-iot-microservice.onrender.com

# Clave de API para autenticación con el servidor IoT
# Si usas multitenancy, este token puede ser específico para el dispositivo
DEVICE_TOKEN=MACMECMIC
# Retrocompatibilidad
IOT_API_KEY=MACMECMIC

GPS_PORT=/dev/ttyS0
